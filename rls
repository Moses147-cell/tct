#!/usr/bin/env bash
set -euo pipefail

VERSION="3.0.0"

RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
RESET="\033[0m"

error(){ echo -e "${RED}❌ $1${RESET}" >&2; exit 1; }
warn(){ echo -e "${YELLOW}⚠️  $1${RESET}"; }
info(){ echo -e "${BLUE}⏳ $1${RESET}"; }
success(){ echo -e "${GREEN}✅ $1${RESET}"; }

require_command(){
 command -v "$1" >/dev/null 2>&1 || error "Required command '$1' not found."
}

require_command git
require_command gh

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || \
 error "Not inside a git repository."

release_exists(){
 gh release view "$1" >/dev/null 2>&1
}

load_notes(){
 if [[ -f notes ]]; then
  cat notes
 fi
}

base_version(){
 echo "$1" | cut -d'-' -f1
}

is_beta(){
 [[ "$1" == *"-beta"* ]]
}

create_or_update_beta(){
 # Strip 'v' prefix if user accidentally included it
 version="${1#v}"
 base=$(base_version "$version")

 info "Preparing beta release v$version"

 body="Beta Version: v$version"
 notes=$(load_notes)

 if [[ -n "$notes" ]]; then
  body="$body

$notes"
 fi

 if git rev-parse beta >/dev/null 2>&1; then
  info "Updating beta tag"
 else
  info "Creating beta tag"
  git tag beta
 fi

 git push -f origin beta >/dev/null 2>&1 || true

 if release_exists beta; then
  info "Updating existing beta release"

  gh release edit beta \
   --title "Release $version" \
   --notes "$body" \
   --prerelease

 else
  info "Creating beta release"

  gh release create beta \
   --title "Release $version" \
   --notes "$body" \
   --prerelease
 fi

 success "Beta release updated → v$version"
}

create_release(){
 # Strip 'v' prefix if user accidentally included it
 version="${1#v}"

 git tag "v$version"
 git push origin "v$version"

 if [[ -f notes ]]; then
  gh release create "v$version" --title "Release $version" --notes-file notes
 else
  # Fallback to auto-generating a beautiful changelog if no notes file exists!
  gh release create "v$version" --title "Release $version" --generate-notes
 fi

 success "Release v$version created."
}

add_assets(){
 version="${1#v}"
 shift

 [[ $# -eq 0 ]] && error "Usage: rls add <version|beta> <file>..."

 release_exists "$version" || \
  error "Release $version does not exist."

 info "Uploading assets"

 gh release upload "$version" "$@" --clobber

 success "Assets uploaded."
}

delete_release(){
 version="${1#v}"

 warn "Deleting release $version"

 gh release delete "$version" -y

 git push --delete origin "$version" 2>/dev/null || true
 git tag -d "$version" 2>/dev/null || true

 success "Release deleted."
}

show_help(){
cat <<EOF
rls - GitHub Release Manager

USAGE
 rls <version>
 rls add <version|beta> <files>
 rls delete <version>

BETA SYSTEM
 Beta versions reuse ONE tag: beta

 Example:
  rls 0.3.4-beta
  rls add beta tct-linux

DOWNLOAD URL
 https://github.com/<repo>/releases/download/beta/<file>

NOTES
 If file 'notes' exists, it is included automatically.
EOF
}

if [[ $# -eq 0 ]]; then
 show_help
 exit 0
fi

cmd="$1"
shift || true

case "$cmd" in

add)
 add_assets "$@"
 ;;

delete)
 delete_release "$1"
 ;;

--help|-h)
 show_help
 ;;

--version|-v)
 echo "rls version $VERSION"
 ;;

*)
 if is_beta "$cmd"; then
  create_or_update_beta "$cmd"
 else
  create_release "$cmd"
 fi
 ;;

esac
